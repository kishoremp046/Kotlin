<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#E6F9FF">

    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Result"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#0A2540"
        android:layout_marginTop="40dp"
        tools:ignore="HardcodedText" />

    <androidx.cardview.widget.CardView
        android:id="@+id/resultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="horizontal"
            android:background="@color/white">

            <TextView
                android:id="@+id/value1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:text="Value 1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#333333"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="="
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#555555"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/value2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:text="Value 2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#333333"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

  <androidx.cardview.widget.CardView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:cardCornerRadius="15dp"
      app:cardBackgroundColor="#a3baff"
      app:cardElevation="30dp"
      android:layout_marginHorizontal="32dp">

      <androidx.appcompat.widget.AppCompatButton
          android:id="@+id/btn"
          android:layout_width="200dp"
          android:layout_height="match_parent"
          android:text="Start"
          android:textAllCaps="false"
          android:textStyle="bold"
          android:textColor="@color/black"
          android:backgroundTint="#a3baff"
          tools:ignore="HardcodedText" />
  </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="130dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="30dp"
        app:cardMaxElevation="100dp"
        app:cardBackgroundColor="#00ee60">

        <Button
            android:id="@+id/name1_Btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#00ee60"
            android:text="Green"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="30dp"
        app:cardBackgroundColor="#f30000">

        <Button
            android:id="@+id/name2_Btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Red"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="#f30000" />

    </androidx.cardview.widget.CardView>







</LinearLayout>