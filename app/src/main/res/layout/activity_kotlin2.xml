<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:id="@+id/kotlin2"
    android:background="#F0F4FF"
    tools:ignore="HardcodedText">

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/output_bg"
        android:gravity="center"
        android:padding="24dp"
        android:text=""
        android:textColor="#e12d59"
        android:textSize="35sp"
        android:textStyle="bold"
        android:visibility="invisible" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Day Finder"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E3A8A"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a number between 1 to 7"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etNumber"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter number (1-7)"
        android:inputType="number"
        android:textSize="16sp"
        android:textColor="#1E3A8A"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:textColorHint="#9CA3AF"
        android:background="@drawable/imput_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="30dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:cardCornerRadius="15dp"
        app:cardBackgroundColor="#20cccc">

        <Button
            android:id="@+id/btnFind"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Find Day"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:backgroundTint="#20cccc" />
    </androidx.cardview.widget.CardView>



</LinearLayout>